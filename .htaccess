RewriteEngine On

# API v1 path-based routing
RewriteRule ^api/v1/(.*)$ api/v1/index.php [L,QSA]

# Payment link slug routing
RewriteRule ^pay/([a-z0-9\-]+)$ pay-link.php?slug=$1 [L,QSA]

# Redirect to index.php if file/directory doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# Deny access to sensitive directories and files
RewriteRule ^storage/ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^app/ - [F,L]
RewriteRule ^includes/ - [F,L]
RewriteRule ^lang/ - [F,L]
RewriteRule ^\.git/ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
# Block install.php after installation (uncomment after install complete)
# RewriteRule ^install\.php$ - [F,L]

# Block access to backup files
<FilesMatch "\.(bak|backup|sql|log|ini|sh|env)$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self)"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # Content Security Policy (updated for Midtrans & AldiQRIS)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://app.sandbox.midtrans.com https://app.midtrans.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://api.sandbox.midtrans.com https://api.midtrans.com; frame-src 'self' https://app.sandbox.midtrans.com https://app.midtrans.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'"

    # HSTS (uncomment in production with HTTPS)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Disable directory browsing
Options -Indexes

# Disable server signature
ServerSignature Off

# PHP settings
<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    # php_value session.cookie_secure 1
    # NOTE: Uncomment session.cookie_secure ONLY if using HTTPS
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite "Lax"
    php_value session.use_only_cookies 1
    php_value session.use_trans_sid 0
    php_value expose_php 0
    php_value upload_max_filesize 5M
    php_value post_max_size 10M
    php_value max_input_vars 1000
</IfModule>
